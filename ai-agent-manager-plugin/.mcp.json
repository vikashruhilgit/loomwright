{
  "mcpServers": {
    "mysql": {
      "command": "uvx",
      "args": ["--from", "vikashruhil-mysql-mcp", "--refresh", "mysql-mcp"],
      "env": {
        "DB_HOST": "${DB_HOST}",
        "DB_USER": "${DB_USER}",
        "DB_PASS": "${DB_PASS}",
        "DB_NAME": "${DB_NAME}",
        "DB_PORT": "${DB_PORT}"
      }
    }
  }
}
