{
  "name": "ai-agent-manager-plugin",
  "version": "10.1.0",
  "description": "AI agents v10.1: Product Owner --brainstorm mode (5-lens multi-mind ideation with debate, scoring, and recommendation). 11 agent roles: Launch Pad, Supervisor v4, Execute Manager, Context-Keeper, Worker, Product Owner (now with --brainstorm), Orchestrator, Code Reviewer (LSP, effort:high, disallowedTools:Write/Edit/NotebookEdit, schema v2), Red Team Reviewer (effort:high), QA Strategist (effort:high), QA Executor. 47 reusable skills. 9 quality gate hooks, persistent agent memory, bundled MySQL MCP server.",
  "author": {
    "name": "vikash ruhil"
  },
  "license": "MIT",
  "mcpServers": {
    "mysql": {
      "command": "uvx",
      "args": ["--from", "vikashruhil-mysql-mcp", "--refresh", "mysql-mcp"],
      "env": {
        "DB_HOST": "${DB_HOST}",
        "DB_USER": "${DB_USER}",
        "DB_PASS": "${DB_PASS}",
        "DB_NAME": "${DB_NAME}",
        "DB_PORT": "${DB_PORT}"
      }
    }
  },
