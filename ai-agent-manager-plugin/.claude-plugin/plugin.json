{
  "name": "ai-agent-manager-plugin",
  "version": "12.0.0",
  "description": "AI agents v12.0.0 — Reliability primitives: inter-subtask output contracts (provides/requires schema), pre-spawn dependency verification gate, scope-expansion adjudication (4-option escalation), effort-tier discipline (xhigh/high/medium across 12 agents), and hardened SubagentStop validation rejecting outputs_gap/toolset_gap drift. WORKER_RESULT schema bumped to v2 with outputs_verified[] + outputs_gap fields. Builds on v11.2.0 (opt-in GitHub Issues telemetry), v11.1.x (inline-execution guard, Phase 4.5 completion-tail invariant), v11.0 (self-heal), v10.3 layers. 12 agent roles, 48 reusable skills, 13 quality gate hooks, persistent agent memory, bundled MySQL MCP server.",
  "author": {
    "name": "vikash ruhil"
  },
  "license": "MIT",
  "mcpServers": {
    "mysql": {
      "command": "uvx",
      "args": ["--from", "vikashruhil-mysql-mcp", "--refresh", "mysql-mcp"],
      "env": {
        "DB_HOST": "${DB_HOST}",
        "DB_USER": "${DB_USER}",
        "DB_PASS": "${DB_PASS}",
        "DB_NAME": "${DB_NAME}",
        "DB_PORT": "${DB_PORT}"
      }
    }
  },
